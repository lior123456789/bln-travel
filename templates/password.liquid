<section class="section" style="min-height: 80vh; display: grid; place-items: center;">
  <div class="container" style="max-width: 480px; text-align: center;">
    <div class="cap" style="margin-bottom: 16px;">Coming Soon</div>
    <h1 style="font-size: clamp(32px, 5vw, 56px); line-height: 1.05;">{{ shop.password_message | default: 'Engineered for movement. Crafted to endure.' }}</h1>

    <form method="post" action="/password" id="login_form" accept-charset="UTF-8" style="margin-top: 32px;">
      <input type="hidden" name="form_type" value="storefront_password">
      <input type="hidden" name="utf8" value="✓">
      <label for="pw" class="cap" style="display: block; margin-bottom: 8px;">Password</label>
      <input type="password" name="password" id="pw" class="input">
      <button type="submit" class="btn btn--full" style="margin-top: 12px;">Enter</button>
    </form>
  </div>
</section>
