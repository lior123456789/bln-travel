<section class="section">
  <div class="container" style="max-width: 420px;">
    <div style="text-align: center; margin-bottom: 32px;">
      <div class="cap" style="margin-bottom: 12px;">Account</div>
      <h1 style="font-size: clamp(28px, 4vw, 40px);">Reset Password</h1>
    </div>
    {% form 'reset_customer_password' %}
      {%- if form.errors -%}<div style="padding: 12px; border: 1px solid #d44; color: #d44; margin-bottom: 16px;">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="field"><label for="Password">New password</label><input type="password" name="customer[password]" id="Password" class="input" required></div>
      <div class="field"><label for="PasswordConfirmation">Confirm password</label><input type="password" name="customer[password_confirmation]" id="PasswordConfirmation" class="input" required></div>
      <button type="submit" class="btn btn--full">Reset</button>
    {% endform %}
  </div>
</section>
