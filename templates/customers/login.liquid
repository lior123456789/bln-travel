<section class="section">
  <div class="container" style="max-width: 420px;">
    <div class="reveal" style="text-align: center; margin-bottom: 32px;">
      <div class="cap" style="margin-bottom: 12px;">Account</div>
      <h1 style="font-size: clamp(28px, 4vw, 40px);">Sign In</h1>
    </div>

    {% form 'customer_login' %}
      {%- if form.errors -%}
        <div style="padding: 12px; border: 1px solid #d44; color: #d44; margin-bottom: 16px;">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="field">
        <label for="CustomerEmail">Email</label>
        <input type="email" name="customer[email]" id="CustomerEmail" class="input" required>
      </div>
      <div class="field">
        <label for="CustomerPassword">Password</label>
        <input type="password" name="customer[password]" id="CustomerPassword" class="input" required>
      </div>
      <button type="submit" class="btn btn--full">Sign In</button>
      <div style="display: flex; justify-content: space-between; margin-top: 16px;" class="cap">
        <a href="/account/register" class="link-grow">Create Account</a>
        <a href="#recover" class="link-grow">Forgot?</a>
      </div>
    {% endform %}

    <div id="recover" style="margin-top: 48px;">
      {% form 'recover_customer_password' %}
        <h2 class="cap" style="margin-bottom: 16px;">Reset Password</h2>
        <div class="field">
          <label for="RecoverEmail">Email</label>
          <input type="email" name="email" id="RecoverEmail" class="input" required>
        </div>
        <button type="submit" class="btn btn--outline btn--full">Send Reset Link</button>
      {% endform %}
    </div>
  </div>
</section>
