<section class="section">
  <div class="container" style="max-width: 720px;">
    <div class="cap" style="margin-bottom: 12px;">Order {{ order.name }}</div>
    <h1 style="font-size: clamp(28px, 4vw, 40px); margin-bottom: 16px;">{{ order.created_at | date: '%B %-d, %Y' }}</h1>
    <p class="cap" style="margin-bottom: 32px;">Status: {{ order.fulfillment_status_label }} · {{ order.financial_status_label }}</p>

    <table style="width: 100%; border-collapse: collapse;">
      <thead><tr style="text-align: left;"><th class="cap" style="padding: 12px 0;">Item</th><th class="cap">Qty</th><th class="cap" style="text-align: right;">Total</th></tr></thead>
      <tbody>
        {%- for line_item in order.line_items -%}
          <tr style="border-top: 1px solid var(--line);">
            <td style="padding: 12px 0;">{{ line_item.title }}</td>
            <td>{{ line_item.quantity }}</td>
            <td style="text-align: right;">{{ line_item.final_line_price | money_without_trailing_zeros }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>

    <div style="margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--line); display: flex; justify-content: space-between; font-family: var(--serif); font-size: 18px;">
      <div>Total</div>
      <div>{{ order.total_price | money_without_trailing_zeros }}</div>
    </div>
  </div>
</section>
