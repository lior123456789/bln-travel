<section class="section">
  <div class="container" style="max-width: 800px;">
    <div class="reveal" style="margin-bottom: 32px;">
      <div class="cap" style="margin-bottom: 12px;">Page</div>
      <h1 style="font-size: clamp(32px, 5vw, 48px); line-height: 1.1;">{{ page.title }}</h1>
    </div>
    <div class="reveal" style="font-family: var(--serif); font-size: 18px; line-height: 1.7; color: var(--ash);">
      {{ page.content }}
    </div>
  </div>
</section>
