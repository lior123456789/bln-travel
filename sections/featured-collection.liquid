{%- assign collection = collections[section.settings.collection] -%}

<section class="section">
  <div class="container">
    <div style="max-width: 640px; margin-bottom: 48px;" class="reveal">
      <div class="cap" style="margin-bottom: 12px;">{{ section.settings.eyebrow | default: 'The Collection' }}</div>
      <h2 style="font-size: clamp(32px, 5vw, 48px); line-height: 1.1; letter-spacing: -0.01em;">
        {{ section.settings.heading | default: 'Three finishes.' }}
      </h2>
    </div>

    <div class="collection-grid reveal">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: 6 -%}
          <a href="{{ product.url }}" class="collection-card">
            <div class="collection-card__image">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}">
              {%- endif -%}
            </div>
            <div class="collection-card__meta">
              <div>
                <div class="collection-card__title">{{ product.title | split: '·' | last | strip }}</div>
                <div class="collection-card__sub">{{ product.type | default: 'Carry-On' }}</div>
              </div>
              <div class="collection-card__price">{{ product.price | money_without_trailing_zeros }}</div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for product in all_products limit: 6 -%}
          <a href="{{ product.url }}" class="collection-card">
            <div class="collection-card__image">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}">
              {%- endif -%}
            </div>
            <div class="collection-card__meta">
              <div>
                <div class="collection-card__title">{{ product.title | split: '·' | last | strip }}</div>
                <div class="collection-card__sub">{{ product.type | default: 'Carry-On' }}</div>
              </div>
              <div class="collection-card__price">{{ product.price | money_without_trailing_zeros }}</div>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text",       "id": "eyebrow",    "label": "Eyebrow",    "default": "The Collection" },
    { "type": "text",       "id": "heading",    "label": "Heading",    "default": "Three finishes." },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [
    { "name": "Featured collection" }
  ]
}
{% endschema %}
